{
  "mcpServers": {
    "firecrawl-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "fc-38a74600e4794626a1dab91a6988a9b9"
      },
      "autoApprove": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_crawl",
        "firecrawl_check_crawl_status",
        "firecrawl_search",
        "firecrawl_extract",
        "firecrawl_deep_research",
        "firecrawl_generate_llmstxt"
      ],
      "alwaysAllow": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_crawl",
        "firecrawl_check_crawl_status",
        "firecrawl_search",
        "firecrawl_extract",
        "firecrawl_deep_research",
        "firecrawl_generate_llmstxt"
      ]
    },
    "crawl4ai": {
      "transport": "sse",
      "url": "https://mcpserver.duckdns.org/mcp/sse",
      "disabled": false,
      "alwaysAllow": [
        "md",
        "html",
        "screenshot",
        "pdf",
        "execute_js",
        "crawl",
        "ask",
        "code",
        "video",
        "markdown",
        "browser"
      ],
      "disabledTools": [
        "pdf"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "autoApprove": [
        "md",
        "html",
        "screenshot",
        "pdf",
        "execute_js",
        "crawl",
        "ask"
      ],
      "timeout": 60,
      "alwaysAllow": [
        "puppeteer_navigate",
        "puppeteer_screenshot",
        "puppeteer_click",
        "puppeteer_fill",
        "puppeteer_select",
        "puppeteer_hover",
        "puppeteer_evaluate",
        "close",
        "puppeteer_close"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": ""
      },
      "alwaysAllow": [
        "resolve-library-id",
        "get-library-docs"
      ]
    }
  }
}