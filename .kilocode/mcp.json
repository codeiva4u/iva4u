{
  "mcpServers": {
    "puppeteer-real-browser": {
      "command": "npx",
      "args": [
        "puppeteer-real-browser-mcp-server@latest"
      ],
      "env": {
        "CHROME_PATH": "C:\\Users\\Ivan-Sunil\\AppData\\Local\\BraveSoftware\\Brave-Browser\\Application\\brave.exe"
      },
      "autoApprove": [
        "browser_init",
        "navigate",
        "get_content",
        "browser_close",
        "click",
        "type",
        "wait",
        "find_selector",
        "random_scroll",
        "solve_captcha"
      ],
      "alwaysAllow": [
        "browser_init",
        "navigate",
        "get_content",
        "browser_close",
        "click",
        "type",
        "wait",
        "find_selector",
        "random_scroll",
        "solve_captcha"
      ],
      "toolConfig": {
        "solve_captcha": {
          "supportedTypes": [
            "recaptcha",
            "hCaptcha", 
            "turnstile"
          ],
          "defaultType": "recaptcha",
          "autoDetect": true
        }
      }
    },
    "firecrawl-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "fc-38a74600e4794626a1dab91a6988a9b9"
      },
      "autoApprove": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_crawl",
        "firecrawl_check_crawl_status",
        "firecrawl_search",
        "firecrawl_extract",
        "firecrawl_deep_research",
        "firecrawl_generate_llmstxt"
      ],
      "alwaysAllow": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_crawl",
        "firecrawl_check_crawl_status",
        "firecrawl_search",
        "firecrawl_extract",
        "firecrawl_deep_research",
        "firecrawl_generate_llmstxt"
      ]
    },
    "crawl4ai": {
      "transport": "sse",
      "url": "https://mcpserver.duckdns.org/mcp/sse",
      "disabled": false,
      "alwaysAllow": [
        "md",
        "html",
        "screenshot",
        "pdf",
        "execute_js",
        "crawl",
        "ask",
        "code",
        "video",
        "markdown",
        "browser"
      ],
      "disabledTools": [
        "pdf"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": ""
      },
      "alwaysAllow": [
        "resolve-library-id",
        "get-library-docs"
      ]
    }
  }
}